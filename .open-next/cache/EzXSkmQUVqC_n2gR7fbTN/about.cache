en whitespace-nowrap\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-house flex-shrink-0\" aria-hidden=\"true\"><path d=\"M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8\"></path><path d=\"M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"></path></svg>Home</a><a id=\"sidebar-link\" class=\"flex items-center gap-3 px-4 py-2.5 text-sm transition-colors overflow-hidden whitespace-nowrap\" href=\"/episodes/latest\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-play flex-shrink-0\" aria-hidden=\"true\"><path d=\"M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z\"></path></svg>Latest Episode</a><a id=\"sidebar-link\" class=\"flex items-center gap-3 px-4 py-2.5 text-sm transition-colors overflow-hidden whitespace-nowrap\" href=\"https://open.spotify.com/show/6EwXjHiWsRiE9SE8GuJJv4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-music2 lucide-music-2 flex-shrink-0\" aria-hidden=\"true\"><circle cx=\"8\" cy=\"18\" r=\"4\"></circle><path d=\"M12 18V2l7 4\"></path></svg>Spotify</a><a id=\"sidebar-link\" class=\"flex items-center gap-3 px-4 py-2.5 text-sm transition-colors overflow-hidden whitespace-nowrap\" href=\"/about\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-info flex-shrink-0\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 16v-4\"></path><path d=\"M12 8h.01\"></path></svg>About</a></div><div class=\"hidden md:flex px-3 pb-4\"><button class=\"w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors mx-auto\" aria-label=\"Toggle sidebar\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-left text-white/60 transition-transform duration-300\" aria-hidden=\"true\"><path d=\"m15 18-6-6 6-6\"></path></svg></button></div></nav><main class=\"flex-1 flex flex-col min-h-screen transition-all duration-300\n        md:ml-[220px]\"><div class=\"flex items-center gap-3 px-4 py-4 border-b border-white/10 md:hidden\"><button class=\"text-white/60 hover:text-white\" aria-label=\"Open menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button><span class=\"text-white text-sm font-medium\">Irregulars</span></div><div class=\"flex-1\"><div class=\"font-sans grid grid-rows-[20px_1fr_20px] items-center justify-items-center min-h-screen p-8 pb-20 gap-16 sm:p-20\"><main class=\"flex flex-col gap-[32px] row-start-2 items-center\"><h1 class=\"text-5xl font-extrabold tracking-tight sm:text-[5rem]\"><span class=\"title\">About the Team</span></h1><div><p class=\"text-lg text-white/70 max-w-auto text-center pb-20\">We are a group of sports enthusiasts who love to talk about the latest news and trends in the world of sports.<br/>We started this podcast as a way to share our passion for sports with others and to connect with like-minded individuals.<br/><br/><strong>Oh yeah and sometimes we have a few drinks and banter at one another.</strong></p><div class=\"flex flex-col gap-6 mt-4\"><div class=\"flex w-full rounded-2xl bg-white shadow-md overflow-hidden\"><div class=\"flex-shrink-0 p-4\"><div class=\"relative h-48 w-48 overflow-hidden rounded-xl\"><img alt=\"Blymm\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fprofile-blymm.png&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fprofile-blymm.png&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fprofile-blymm.png&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fprofile-blymm.png&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fprofile-blymm.png&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fprofile-blymm.png&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fprofile-blymm.png&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fprofile-blymm.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fprofile-blymm.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fprofile-blymm.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fprofile-blymm.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fprofile-blymm.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fprofile-blymm.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fprofile-blymm.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fprofile-blymm.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fprofile-blymm.png&amp;w=3840&amp;q=75\"/></div></div><div class=\"flex flex-col flex-1 py-4 pr-6\"><h2 class=\"text-2xl font-bold text-gray-900 mb-1\">Blymm</h2><h4 class=\"text-sm font-medium text-gray-500 mb-2\">Creator and executive producer of The Irregulars Sports Show</h4><p class=\"text-gray-600 text-sm mb-2\"><span class=\"font-semibold\">Teams:</span> <!-- -->Teams Placeholder</p><p class=\"text-gray-600 leading-relaxed whitespace-pre-line flex-1\">Formerly of the hip hop group Rainwater Conglomerate, one half of the duo Baby C &amp; Blymm</p><p class=\"text-gray-400 text-sm italic mt-3\">&quot;<!-- -->We are making sports cool again!<!-- -->&quot;</p></div></div><div class=\"flex w-full rounded-2xl bg-white shadow-md overflow-hidden\"><div class=\"flex-shrink-0 p-4\"><div class=\"relative h-48 w-48 overflow-hidden rounded-xl\"><img alt=\"Coach\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fprofile-coach.jpeg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fprofile-coach.jpeg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fprofile-coach.jpeg&amp;w=3840&amp;q=75\"/></div></div><div class=\"flex flex-col flex-1 py-4 pr-6\"><h2 class=\"text-2xl font-bold text-gray-900 mb-1\">Coach</h2><h4 class=\"text-sm font-medium text-gray-500 mb-2\">Former Head Coach for Kamiak J.V. Football</h4><p class=\"text-gray-600 text-sm mb-2\"><span class=\"font-semibold\">Teams:</span> <!-- -->Seattle Seahawks, San Francisco Giants, and any University of Tulsa Golden Hurricane team</p><p class=\"text-gray-600 leading-relaxed whitespace-pre-line flex-1\">Raising two sons and proud of it!</p><p class=\"text-gray-400 text-sm italic mt-3\">&quot;<!-- -->If it isn&#x27;t fun, then what&#x27;s the point?<!-- -->&quot;</p></div></div><div class=\"flex w-full rounded-2xl bg-white shadow-md overflow-hidden\"><div class=\"flex-shrink-0 p-4\"><div class=\"relative h-48 w-48 overflow-hidden rounded-xl\"><img alt=\"Luke 3:16\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fprofile-luke316.jpeg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fprofile-luke316.jpeg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fprofile-luke316.jpeg&amp;w=3840&amp;q=75\"/></div></div><div class=\"flex flex-col flex-1 py-4 pr-6\"><h2 class=\"text-2xl font-bold text-gray-900 mb-1\">Luke 3:16</h2><p class=\"text-gray-600 text-sm mb-2\"><span class=\"font-semibold\">Teams:</span> <!-- -->Kansas City Chiefs, Seattle Mariners, Seattle Supersonics, Oklahoma State University</p><p class=\"text-gray-600 leading-relaxed whitespace-pre-line flex-1\">WESCO South Assistant Wrestling Coach of the Year  in 2008, Former Head Coach of the Kamiak High School J.V. Football team</p><p class=\"text-gray-400 text-sm italic mt-3\">&quot;<!-- -->Placeholder quote.<!-- -->&quot;</p></div></div><div class=\"flex w-full rounded-2xl bg-white shadow-md overflow-hidden\"><div class=\"flex-shrink-0 p-4\"><div class=\"relative h-48 w-48 overflow-hidden rounded-xl\"><img alt=\"ZeeFeezee\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fprofile-ZeeFeezee.jpeg&amp;w=3840&amp;q=75\"/></div></div><div class=\"flex flex-col flex-1 py-4 pr-6\"><h2 class=\"text-2xl font-bold text-gray-900 mb-1\">ZeeFeezee</h2><p class=\"text-gray-600 text-sm mb-2\"><span class=\"font-semibold\">Teams:</span> <!-- -->Chicago Bears, Chicago White Sox, SeattleSeahawks</p><p class=\"text-gray-600 leading-relaxed whitespace-pre-line flex-1\">Placeholder bio.</p><p class=\"text-gray-400 text-sm italic mt-3\">&quot;<!-- -->Do dope shit, with dope people!<!-- -->&quot;</p></div></div><div class=\"flex w-full rounded-2xl bg-white shadow-md overflow-hidden\"><div class=\"flex-shrink-0 p-4\"><div class=\"relative h-48 w-48 overflow-hidden rounded-xl\"><img alt=\"codeMonkeyHopeful\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fprofile-ryan.jpg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fprofile-ryan.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fprofile-ryan.jpg&amp;w=3840&amp;q=75\"/></div></div><div class=\"flex flex-col flex-1 py-4 pr-6\"><h2 class=\"text-2xl font-bold text-gray-900 mb-1\">codeMonkeyHopeful</h2><h4 class=\"text-sm font-medium text-gray-500 mb-2\">Head Dev in Charge (yup HDIC)</h4><p class=\"text-gray-600 text-sm mb-2\"><span class=\"font-semibold\">Teams:</span> <!-- -->The fuck is a team? Ohhh, ohh, sports, go team!</p><p class=\"text-gray-600 leading-relaxed whitespace-pre-line flex-1\">Built this site and love the crew! Grew up in Ohio, went to OSU, married a wolverine... Love all things tech!</p><p class=\"text-gray-400 text-sm italic mt-3\">&quot;<!-- -->There are only two mistakes one can make along the road to truth; not going all the way, and not starting.<!-- -->&quot;</p></div></div></div></div></main></div><!--$--><!--/$--></div><footer class=\"sticky bottom-0 flex gap-[24px] flex-wrap items-center justify-center p-4 bg-black\"><a href=\"https://open.spotify.com/show/6EwXjHiWsRiE9SE8GuJJv4\" target=\"_blank\" rel=\"noopener noreferrer\"><img id=\"spotify-logo\" alt=\"Logo of The Irregular Sports Show\" width=\"50\" height=\"50\" decoding=\"async\" data-nimg=\"1\" class=\"dark:invert\" style=\"color:transparent\" src=\"/_next/static/media/spotify.0kocg-uw1rfl8.svg\"/></a></footer></main></div><script src=\"/_next/static/chunks/0gxwci3e5-ykx.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[14131,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"SidebarProvider\\\"]\\n3:I[85610,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n4:I[52959,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n5:I[39756,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n6:I[37457,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n7:I[5500,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"Image\\\"]\\n12:I[68027,[\\\"/_next/static/chunks/04o~.4_z2u7et.js\\\",\\\"/_next/static/chunks/0d3